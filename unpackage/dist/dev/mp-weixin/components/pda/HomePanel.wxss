
.home-page.data-v-5a6d3209 {
	min-height: 100vh;
	padding: 0 40rpx;
	padding-top: calc(var(--status-bar-height, 44px) + 40rpx);
	box-sizing: border-box;
	background: #ffffff;
}
.header.data-v-5a6d3209 {
	display: flex;
	justify-content: space-between;
	align-items: center;
	margin-bottom: 48rpx;
}
.brand.data-v-5a6d3209 {
	display: flex;
	flex-direction: column;
}
.brand-name.data-v-5a6d3209 {
	font-size: 56rpx;
	font-weight: 700;
	color: #1f2937;
	letter-spacing: 4rpx;
}
.brand-slogan.data-v-5a6d3209 {
	margin-top: 8rpx;
	font-size: 24rpx;
	color: #6b7280;
}
.user-info.data-v-5a6d3209 {
	display: flex;
	align-items: center;
	gap: 20rpx;
}
.welcome.data-v-5a6d3209 {
	font-size: 28rpx;
	color: #374151;
	font-weight: 500;
}
.logout-btn.data-v-5a6d3209 {
	width: 64rpx;
	height: 64rpx;
	border-radius: 50%;
	background: rgba(255, 255, 255, 0.8);
	box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
	display: flex;
	align-items: center;
	justify-content: center;
}
.logout-icon.data-v-5a6d3209 {
	width: 36rpx;
	height: 36rpx;
}
.card-container.data-v-5a6d3209 {
	display: flex;
	flex-wrap: wrap;
	gap: 32rpx;
}
.function-card.data-v-5a6d3209 {
	width: calc((100% - 32rpx) / 2);
	min-height: 280rpx;
	padding: 32rpx;
	box-sizing: border-box;
	border-radius: 32rpx;
	display: flex;
	flex-direction: column;
	box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.12);
}
.card-icon.data-v-5a6d3209 {
	width: 96rpx;
	height: 96rpx;
	border-radius: 24rpx;
	background: rgba(255, 255, 255, 0.25);
	display: flex;
	align-items: center;
	justify-content: center;
	margin-bottom: 24rpx;
}
.card-icon-image.data-v-5a6d3209 {
	background: linear-gradient(145deg, #5b95ff 0%, #3e7bea 100%);
	box-shadow: 0 10rpx 20rpx rgba(29, 78, 216, 0.28);
}
.icon-img.data-v-5a6d3209 {
	width: 84rpx;
	height: 84rpx;
}
.icon-fallback.data-v-5a6d3209 {
	font-size: 48rpx;
	line-height: 1;
	color: #ffffff;
}
.card-content.data-v-5a6d3209 {
	margin-top: 30rpx;
}
.card-title.data-v-5a6d3209 {
	display: block;
	margin-bottom: 12rpx;
	font-size: 36rpx;
	font-weight: 700;
	color: #ffffff;
}
.card-desc.data-v-5a6d3209 {
	font-size: 24rpx;
	line-height: 1.4;
	color: rgba(255, 255, 255, 0.85);
}
.card-blue.data-v-5a6d3209 {
	background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
}
